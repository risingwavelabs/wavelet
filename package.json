{
  "name": "wavelet-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/server",
    "test": "vitest run",
    "lint": "eslint packages/ --ext .ts",
    "typecheck": "tsc --build packages/*/tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "vitest": "^4.1.0"
  },
  "version": "0.1.0"
}
